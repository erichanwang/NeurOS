#compdef nn

_nn() {
  local -a commands
  commands=(
    '-i[Interactive chat mode]'
    '-h[Show help]'
    '--help[Show help]'
  )
  _arguments $commands
}
_nn

#compdef neuros-model

_neuros_model() {
  local -a commands
  commands=(
    'list[List installed models]'
    'pull[Download a model]'
    'remove[Remove a model]'
    'switch[Set default model]'
    'info[Show model details]'
    'search[Search available models]'
    'benchmark[Benchmark inference speed]'
    'compare[Compare multiple models]'
  )
  _arguments '1: :{_describe command commands}'
}
_neuros_model

