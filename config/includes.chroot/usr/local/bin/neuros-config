#!/usr/bin/env python3
"""
neuros-config — NeurOS Configuration Manager
Central configuration manager for all NeurOS tools with import/export.

Usage:
  neuros-config show                     Show full configuration
  neuros-config get <key>                Get a config value
  neuros-config set <key> <value>        Set a config value
  neuros-config export                   Export all config
  neuros-config import <file>            Import config from file
  neuros-config reset                    Reset to defaults
"""

import sys
import os
import json
import argparse
import shutil
from datetime import datetime
from pathlib import Path

CONFIG_DIR = os.path.expanduser("~/.config/neuros")
MAIN_CONFIG = os.path.join(CONFIG_DIR, "config.json")

DEFAULTS = {
    "model": "mistral",
    "ollama_url": "http://localhost:11434",
    "ollama_host": "127.0.0.1",
    "ollama_port": 11434,
    "chat_port": 11435,
    "mcp_port": 11436,
    "auto_start_llm": True,
    "auto_start_chat": False,
    "theme": "dark",
    "notifications": True,
    "history_size": 1000,
    "default_language": "eng",
    "screenshot_dir": "~/Pictures/NeurOS",
    "backup_compression": True,
    "log_level": "info"
}


def ensure_dirs():
    os.makedirs(CONFIG_DIR, exist_ok=True)
    if not os.path.exists(MAIN_CONFIG):
        save_config(DEFAULTS)


def load_config():
    if os.path.exists(MAIN_CONFIG):
        try:
            with open(MAIN_CONFIG) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            return DEFAULTS.copy()
    return DEFAULTS.copy()


def save_config(config):
    with open(MAIN_CONFIG, "w") as f:
        json.dump(config, f, indent=2)


def get_nested(config, key):
    parts = key.split(".")
    val = config
    for part in parts:
        if isinstance(val, dict):
            val = val.get(part)
        else:
            return None
    return val


def set_nested(config, key, value):
    parts = key.split(".")
    d = config
    for part in parts[:-1]:
        if part not in d:
            d[part] = {}
        d = d[part]
    d[parts[-1]] = coerce_type(value)
    save_config(config)


def coerce_type(value):
    if value.lower() in ("true", "yes", "on"):
        return True
    if value.lower() in ("false", "no", "off"):
        return False
    if value.isdigit():
        return int(value)
    try:
        return float(value)
    except ValueError:
        return value


def export_config(output_file):
    config = load_config()
    config["export_timestamp"] = datetime.now().isoformat()
    config["export_source"] = os.uname().nodename if hasattr(os, "uname") else "neurOS"
    with open(output_file, "w") as f:
        json.dump(config, f, indent=2)
    print(f"Config exported to: {output_file}")


def import_config(input_file):
    if not os.path.exists(input_file):
        print(f"File not found: {input_file}")
        return
    with open(input_file) as f:
        imported = json.load(f)
    imported.pop("export_timestamp", None)
    imported.pop("export_source", None)
    save_config(imported)
    print(f"Config imported from: {input_file}")


def show_config():
    config = load_config()
    print(f"{'Key':<30} {'Value'}")
    print("-" * 50)
    for key, value in sorted(config.items()):
        print(f"{key:<30} {value}")


def show_llm_config():
    llm_path = os.path.join(CONFIG_DIR, "llm.conf")
    if os.path.exists(llm_path):
        print(f"--- llm.conf ({llm_path}) ---")
        with open(llm_path) as f:
            print(f.read())
    else:
        print("llm.conf not found. Defaults will be used.")


def main():
    ensure_dirs()
    parser = argparse.ArgumentParser(description="NeurOS Configuration Manager")
    sub = parser.add_subparsers(dest="cmd")

    sub.add_parser("show", help="Show full configuration")

    get_p = sub.add_parser("get", help="Get a config value")
    get_p.add_argument("key", help="Config key (use dots for nested)")

    set_p = sub.add_parser("set", help="Set a config value")
    set_p.add_argument("key", help="Config key")
    set_p.add_argument("value", help="Config value")

    export_p = sub.add_parser("export", help="Export configuration")
    export_p.add_argument("file", nargs="?", default="neuros-config.json",
                          help="Output file")

    import_p = sub.add_parser("import", help="Import configuration")
    import_p.add_argument("file", help="Input file")

    sub.add_parser("reset", help="Reset to defaults")

    args = parser.parse_args()

    if args.cmd == "show":
        show_config()
        show_llm_config()
    elif args.cmd == "get":
        config = load_config()
        val = get_nested(config, args.key)
        print(val if val is not None else f"Key not found: {args.key}")
    elif args.cmd == "set":
        set_nested(load_config(), args.key, args.value)
        print(f"Set {args.key} = {args.value}")
    elif args.cmd == "export":
        export_config(args.file)
    elif args.cmd == "import":
        import_config(args.file)
    elif args.cmd == "reset":
        if os.path.exists(MAIN_CONFIG):
            backup = MAIN_CONFIG + ".bak"
            shutil.copy(MAIN_CONFIG, backup)
            print(f"Backup saved to: {backup}")
        save_config(DEFAULTS)
        print("Config reset to defaults.")
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
