#!/usr/bin/env python3
"""
neuros-plan — NeurOS AI Project Planner
Breaks down projects into tasks, estimates effort, tracks dependencies,
and generates actionable roadmaps. Works with Markdown and JSON output.

Usage:
  neuros-plan "build a todo app with React and FastAPI"
  neuros-plan --from-spec spec.md
  neuros-plan --track project.json
  neuros-plan --gantt project.json
  neuros-plan --export project.json --format md
"""

import sys
import os
import json
import argparse
import urllib.request
import urllib.error
from datetime import datetime

CONFIG_DIR = os.path.expanduser("~/.config/neuros")
PLAN_DIR = os.path.expanduser("~/.local/share/neuros/plans")

os.makedirs(PLAN_DIR, exist_ok=True)


def read_config():
    config = {"model": "mistral", "ollama_url": "http://localhost:11434"}
    config_path = os.path.join(CONFIG_DIR, "llm.conf")
    if os.path.exists(config_path):
        with open(config_path) as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("["):
                    k, v = line.split("=", 1)
                    config[k.strip()] = v.strip().strip('"').strip("'")
    return config


def ollama_generate(prompt, max_tokens=2500):
    config = read_config()
    try:
        req = urllib.request.Request(
            f"{config['ollama_url']}/api/generate",
            data=json.dumps({
                "model": config["model"], "prompt": prompt, "stream": False,
                "options": {"num_predict": max_tokens, "temperature": 0.3}
            }).encode(),
            headers={"Content-Type": "application/json"}
        )
        resp = urllib.request.urlopen(req, timeout=180)
        return json.loads(resp.read().decode()).get("response", "").strip()
    except Exception:
        return None


def generate_plan(goal):
    prompt = (
        f"Create a detailed project plan in JSON format for this goal. "
        f"Include tasks with dependencies, estimated hours, priority, and phases.\n\n"
        f"GOAL: {goal}\n\n"
        f"Return valid JSON with this structure:\n"
        f'{{"goal": "...", "phases": [{{"name": "...", "tasks": ['
        f'{{"id": 1, "title": "...", "description": "...", "hours": 4.0, '
        f'"priority": "high|medium|low", "dependencies": [2, 3], '
        f'"deliverable": "..."}}]}}]}}'
    )
    response = ollama_generate(prompt, max_tokens=4000)
    if response:
        try:
            return json.loads(response)
        except json.JSONDecodeError:
            pass
    return None


def generate_from_spec(spec_path):
    if not os.path.exists(spec_path):
        return f"Spec file not found: {spec_path}"
    with open(spec_path) as f:
        spec = f.read()[:5000]
    prompt = (
        f"Based on this project specification, create a detailed implementation "
        f"plan with phases, tasks, estimates, and dependencies. Return as JSON.\n\n"
        f"SPECIFICATION:\n{spec}\n\n"
        f"Return JSON with: phases -> tasks (id, title, desc, hours, priority, deps)"
    )
    response = ollama_generate(prompt, max_tokens=4000)
    if response:
        try:
            return json.loads(response)
        except json.JSONDecodeError:
            pass
    return None


def display_plan(plan):
    print(f"\n📋 PROJECT PLAN: {plan.get('goal', 'Untitled')}\n")
    print("=" * 60)
    total_hours = 0
    total_tasks = 0

    for phase in plan.get("phases", []):
        print(f"\n🔹 PHASE: {phase['name']}")
        print("-" * 40)
        for task in phase.get("tasks", []):
            priority_icon = {"high": "🔴", "medium": "🟡", "low": "🟢"}.get(
                task.get("priority", "medium"), "⚪"
            )
            deps = f" (depends on: {', '.join(map(str, task.get('dependencies', [])))})" if task.get("dependencies") else ""
            hours = task.get("hours", 0)
            print(f"  {priority_icon} [{task['id']}] {task['title']} ({hours}h){deps}")
            if task.get("description"):
                print(f"      {task['description'][:100]}")
            total_hours += hours
            total_tasks += 1

    print(f"\n{'='*60}")
    print(f"  📊 {total_tasks} tasks across {len(plan.get('phases', []))} phases")
    print(f"  ⏱️  Estimated total: {total_hours:.0f} hours ({total_hours/8:.1f} days)")
    print()


def export_markdown(plan):
    md = f"# Project Plan: {plan.get('goal', 'Untitled')}\n\n"
    md += f"> Generated by NeurOS on {datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n"

    for phase in plan.get("phases", []):
        md += f"## {phase['name']}\n\n"
        for task in phase.get("tasks", []):
            priority = task.get("priority", "medium").upper()
            deps = f" (depends on: #{', #'.join(map(str, task.get('dependencies', []))))}" if task.get("dependencies") else ""
            md += f"- [ ] **[{priority}]** {task['title']} — {task.get('hours', 0)}h{deps}\n"
            if task.get("description"):
                md += f"  - {task['description']}\n"
        md += "\n"

    total_hours = sum(t.get("hours", 0) for p in plan.get("phases", []) for t in p.get("tasks", []))
    md += f"---\n**Total: {total_hours:.0f}h / {total_hours/8:.1f} days**\n"
    return md


def main():
    parser = argparse.ArgumentParser(description="NeurOS AI Project Planner")
    parser.add_argument("goal", nargs="?", help="Project goal to plan")
    parser.add_argument("--from-spec", "-f", help="Generate plan from spec file")
    parser.add_argument("--track", "-t", help="Track progress on a saved plan")
    parser.add_argument("--export", "-e", help="Export plan file")
    parser.add_argument("--format", choices=["md", "json"], default="md",
                        help="Export format")
    parser.add_argument("--save", "-s", action="store_true",
                        help="Save plan to disk")
    parser.add_argument("--list", "-l", action="store_true",
                        help="List saved plans")

    args = parser.parse_args()

    if args.list:
        plans = [f for f in os.listdir(PLAN_DIR) if f.endswith(".json")]
        if plans:
            for p in sorted(plans):
                plan_path = os.path.join(PLAN_DIR, p)
                with open(plan_path) as f:
                    data = json.load(f)
                print(f"  📋 {p}: {data.get('goal', 'Untitled')[:60]}")
        else:
            print("No saved plans.")
        return

    if args.export:
        plan_path = os.path.join(PLAN_DIR, args.export)
        if not os.path.exists(plan_path) and not args.export.endswith(".json"):
            plan_path = args.export
        if not os.path.exists(plan_path):
            print(f"Plan not found: {args.export}")
            return
        with open(plan_path) as f:
            plan = json.load(f)
        if args.format == "md":
            md = export_markdown(plan)
            out_path = plan_path.replace(".json", ".md")
            with open(out_path, "w") as f:
                f.write(md)
            print(f"Exported to: {out_path}")
        else:
            print(json.dumps(plan, indent=2))
        return

    if args.track:
        plan_path = os.path.join(PLAN_DIR, args.track)
        if not os.path.exists(plan_path) and not args.track.endswith(".json"):
            plan_path = args.track
        if not os.path.exists(plan_path):
            print(f"Plan not found: {args.track}")
            return

    if args.from_spec:
        plan = generate_from_spec(args.from_spec)
    elif args.goal:
        print(f"🧠 Generating plan for: {args.goal}\n")
        plan = generate_plan(args.goal)
    else:
        parser.print_help()
        return

    if plan:
        display_plan(plan)

        if args.save:
            slug = (args.goal or "plan").lower()[:40].replace(" ", "_")
            fpath = os.path.join(PLAN_DIR, f"{slug}.json")
            plan["created"] = datetime.now().isoformat()
            plan["goal"] = plan.get("goal", args.goal or "Untitled")
            with open(fpath, "w") as f:
                json.dump(plan, f, indent=2)
            print(f"  💾 Saved to: {fpath}")
    else:
        print("Failed to generate plan. Is Ollama running?")


if __name__ == "__main__":
    main()
