#!/usr/bin/env python3
"""
neuros-dashboard — NeurOS Remote System Dashboard
Web-based system monitoring with real-time health metrics, alerts,
autofix history, and AI-powered insights. Integrates with neuros-health data.

Usage:
  neuros-dashboard                       Start dashboard on port 11436
  neuros-dashboard --port 8080            Custom port
  neuros-dashboard --public               Listen on all interfaces
"""

import sys
import os
import json
import time
import threading
import subprocess
import argparse
from datetime import datetime
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse

DEFAULT_PORT = 11436
HEALTH_DIR = os.path.expanduser("~/.local/share/neuros/health")
HEALTH_FILE = os.path.join(HEALTH_DIR, "health_history.json")
AUTOFIX_DIR = os.path.expanduser("~/.local/share/neuros/autofix")
AUTOFIX_FILE = os.path.join(AUTOFIX_DIR, "history.json")
UPDATE_DIR = os.path.expanduser("~/.local/share/neuros/update")
UPDATE_FILE = os.path.join(UPDATE_DIR, "update_history.json")

os.makedirs(HEALTH_DIR, exist_ok=True)


def get_metrics():
    """Collect current system metrics."""
    try:
        cpu_idle = float(subprocess.check_output(
            ["bash", "-c", "top -bn1 | grep 'Cpu' | awk '{print $8}'"],
            text=True, timeout=5
        ).strip())
    except Exception:
        cpu_idle = 100.0

    try:
        mem = subprocess.check_output(
            ["bash", "-c", "free -m | grep Mem | awk '{print $3,$2}'"],
            text=True, timeout=5
        ).strip().split()
        mem_used = int(mem[0]) if len(mem) >= 1 else 0
        mem_total = int(mem[1]) if len(mem) >= 2 else 1
    except Exception:
        mem_used, mem_total = 0, 1

    try:
        disk = subprocess.check_output(
            ["bash", "-c", "df / | tail -1 | awk '{print $5}'"],
            text=True, timeout=5
        ).strip().replace("%", "")
    except Exception:
        disk = "0"

    try:
        load = subprocess.check_output(
            ["bash", "-c", "cat /proc/loadavg | awk '{print $1,$2,$3}'"],
            text=True, timeout=5
        ).strip()
    except Exception:
        load = "?"

    try:
        uptime = subprocess.check_output(
            ["uptime", "-p"], text=True, timeout=5
        ).strip()
    except Exception:
        uptime = "?"

    try:
        temp = subprocess.check_output(
            ["bash", "-c", "sensors 2>/dev/null | grep -E 'Package|temp1' | head -1 | awk '{print $2}'"],
            text=True, timeout=5
        ).strip()
    except Exception:
        temp = "?"

    return {
        "timestamp": datetime.now().isoformat(),
        "cpu": round(100 - cpu_idle, 1),
        "memory_percent": round(mem_used / mem_total * 100, 1) if mem_total > 0 else 0,
        "memory_used": mem_used,
        "memory_total": mem_total,
        "disk_percent": float(disk) if disk.replace(".", "").isdigit() else 0,
        "load": load,
        "uptime": uptime,
        "temperature": temp,
    }


def get_recent_autofix(n=20):
    if not os.path.exists(AUTOFIX_FILE):
        return []
    try:
        with open(AUTOFIX_FILE) as f:
            history = json.load(f)
        return history[-n:]
    except Exception:
        return []


def get_recent_updates(n=10):
    if not os.path.exists(UPDATE_FILE):
        return []
    try:
        with open(UPDATE_FILE) as f:
            history = json.load(f)
        return history[-n:]
    except Exception:
        return []


class DashboardHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path

        if path == "/" or path == "/index.html":
            self.serve_html()
        elif path == "/api/metrics":
            self.serve_json(get_metrics())
        elif path == "/api/history":
            self.serve_history()
        elif path == "/api/autofix":
            self.serve_json(get_recent_autofix(20))
        elif path == "/api/updates":
            self.serve_json(get_recent_updates(10))
        elif path == "/api/health":
            self.serve_json({
                "metrics": get_metrics(),
                "autofix": get_recent_autofix(5),
                "updates": get_recent_updates(5)
            })
        else:
            self.send_error(404)

    def serve_json(self, data):
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(json.dumps(data).encode("utf-8"))

    def serve_history(self):
        history = []
        if os.path.exists(HEALTH_FILE):
            try:
                with open(HEALTH_FILE) as f:
                    history = json.load(f)
            except Exception:
                pass

        metrics = []
        for entry in history[-60:]:
            metrics.append({
                "t": entry.get("timestamp", ""),
                "cpu": entry.get("cpu_percent", 0),
                "mem": entry.get("memory_percent", 0),
                "disk": entry.get("disk_percent", 0),
            })
        self.serve_json(metrics)

    def serve_html(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.end_headers()
        self.wfile.write(DASHBOARD_HTML.encode("utf-8"))

    def log_message(self, format, *args):
        pass


DASHBOARD_HTML = r"""<!DOCTYPE html>
<html lang="en">
