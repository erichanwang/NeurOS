<script>
async function refresh() {
  try {
    const [hp, af, up] = await Promise.all([
      fetch('/api/history').then(r=>r.json()),
      fetch('/api/autofix').then(r=>r.json()),
      fetch('/api/updates').then(r=>r.json())
    ]);

    // Live metrics (last entry)
    if (hp.length > 0) {
      const m = hp[hp.length - 1];
      updateMetric('cpuVal', m.cpu + '%', m.cpu);
      updateMetric('memVal', m.mem + '%', m.mem);
      updateMetric('diskVal', m.disk + '%', m.disk);
      document.getElementById('cpuSub').textContent = 'Load: ' + (m.load || '?');
      document.getElementById('memSub').textContent = (m.memory_used || '?') + ' MB / ' + (m.memory_total || '?') + ' MB';
      document.getElementById('sysUptime').textContent = 'Uptime: ' + (m.uptime || '?');
      document.getElementById('sysTemp').textContent = 'Temp: ' + (m.temperature || '?');
      updateGauge('cpuGauge', m.cpu, 100);
      updateGauge('memGauge', m.mem, 100);
      updateGauge('diskGauge', m.disk, 100);

      const dot = document.getElementById('sysDot');
      const status = document.getElementById('sysStatus');
      if (m.cpu > 90 || m.mem > 90 || m.disk > 95) {
        dot.className = 'status-dot crit'; status.textContent = 'Critical';
      } else if (m.cpu > 70 || m.mem > 80 || m.disk > 85) {
        dot.className = 'status-dot warn'; status.textContent = 'Warning';
      } else {
        dot.className = 'status-dot online'; status.textContent = 'Healthy';
      }
    }

    // Chart
    if (hp.length > 1) {
      const maxPts = 60; const w = 600, h = 200;
      const pts = hp.slice(-maxPts);
      const scale = (i, max) => 20 + (h - 40) * (1 - i / max);
      ['cpu','mem','disk'].forEach(k => {
        const line = document.getElementById(k + 'Line');
        const points = pts.map((p, i) => {
          const x = (i / (pts.length - 1)) * w;
          const y = scale((p[k] || 0), 100);
          return x + ',' + y;
        }).join(' ');
        line.setAttribute('points', points);
      });
    }

    // Autofix log
    const afDiv = document.getElementById('autofixLog');
    afDiv.innerHTML = af.length === 0
      ? '<div class="log-entry"><span class="log-icon">[ok]</span> No autofix actions yet</div>'
      : af.slice(-10).reverse().map(h => {
          const icon = h.success ? '[ok]' : '[fail]';
          const ts = (h.timestamp || '').slice(11, 19);
          return `<div class="log-entry"><span class="log-icon">${icon}</span><span class="time">${ts}</span>${h.action}: ${(h.target || h.command || '').slice(0, 50)}</div>`;
        }).join('');

    // Update log
    const upDiv = document.getElementById('updateLog');
    upDiv.innerHTML = up.length === 0
      ? '<div class="log-entry"><span class="log-icon"></span> No updates yet</div>'
      : up.slice(-10).reverse().map(h => {
          const icon = h.success ? '[ok]' : '[fail]';
          const ts = (h.timestamp || '').slice(11, 19);
          return `<div class="log-entry"><span class="log-icon">${icon}</span><span class="time">${ts}</span>${h.action}: ${(h.details || '').slice(0, 40)}</div>`;
        }).join('');
  } catch(e) { console.error(e); }

  document.getElementById('clock').textContent = new Date().toLocaleTimeString();
}

function updateMetric(id, text, pct) {
  document.getElementById(id).textContent = text;
  document.getElementById(id).style.color = pct > 90 ? 'var(--red)' : pct > 70 ? 'var(--yellow)' : 'var(--text)';
}

function updateGauge(id, pct, max) {
  document.getElementById(id).style.width = Math.min(pct / max * 100, 100) + '%';
}

refresh();
setInterval(refresh, 5000);
</script>
</body>
</html>"""


def main():
    parser = argparse.ArgumentParser(description="NeurOS Remote System Dashboard")
    parser.add_argument("--port", "-p", type=int, default=DEFAULT_PORT)
    parser.add_argument("--public", action="store_true", help="Listen on all interfaces")
    args = parser.parse_args()

    host = "0.0.0.0" if args.public else "127.0.0.1"
    server = HTTPServer((host, args.port), DashboardHandler)
    url = f"http://{'localhost' if not args.public else host}:{args.port}"

    print(f"""
╔══════════════════════════════════════════╗
║         NeurOS System Dashboard          ║
║       Real-time system monitoring        ║
╠══════════════════════════════════════════╣
║  URL:  {url:<32}║
╚══════════════════════════════════════════╝

Press Ctrl+C to stop.
""")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\\nShutting down...")
        server.shutdown()


if __name__ == "__main__":
    main()
