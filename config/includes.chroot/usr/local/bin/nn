#!/usr/bin/env python3
"""
nn — NeurOS Terminal Assistant
Usage:
  nn "your question"
  nn "explain this" ./path/to/file
  nn -i   (interactive mode)
"""

import sys, os, subprocess, json
try:
    import requests
except ImportError:
    print("requests not installed. Run: pip3 install requests")
    sys.exit(1)

OLLAMA_URL = "http://localhost:11434/api/generate"
CONFIG_PATH = os.path.expanduser("~/.config/neuros/llm.conf")
DEFAULT_MODEL = "mistral"

def get_model():
    try:
        with open(CONFIG_PATH) as f:
            for line in f:
                line = line.strip()
                # Parse both flat key=value and TOML-style key = "value"
                if '=' in line and not line.startswith('['):
                    key, val = line.split('=', 1)
                    if key.strip() == "model":
                        return val.strip().strip('"').strip("'")
    except:
        pass
    return DEFAULT_MODEL

def get_context_config():
    """Read opt-in system-context settings from the [context] section of
    llm.conf. Every source defaults to False (off) unless the config
    explicitly turns it on, including when the section is missing entirely."""
    settings = {"window_title": False, "clipboard": False, "recent_files": False}
    section = None
    try:
        with open(CONFIG_PATH) as f:
            for line in f:
                line = line.strip()
                if line.startswith('['):
                    section = line.strip('[]').strip()
                    continue
                if section == "context" and '=' in line:
                    key, val = line.split('=', 1)
                    key = key.strip()
                    val = val.strip().strip('"').strip("'").lower()
                    if key in settings:
                        settings[key] = val in ("true", "1", "yes", "on")
    except:
        pass
    return settings

def get_active_window_title():
    """Return the title of the focused window via xdotool, if installed.
    Local only: never sent anywhere but the local Ollama prompt."""
    try:
        out = subprocess.check_output(
            ["xdotool", "getactivewindow", "getwindowname"],
            stderr=subprocess.DEVNULL, text=True, timeout=2).strip()
        return out
    except:
        return ""

def get_clipboard_contents():
    """Return current clipboard text via xclip or xsel, if installed."""
    for cmd in (["xclip", "-selection", "clipboard", "-o"],
                ["xsel", "--clipboard", "--output"]):
        try:
            out = subprocess.check_output(
                cmd, stderr=subprocess.DEVNULL, text=True, timeout=2)
            return out[:2000]
        except:
            continue
    return ""

def get_recent_files(limit=10):
    """Return paths of files under $HOME modified in the last 7 days."""
    home = os.path.expanduser("~")
    try:
        result = subprocess.run(
            ["find", home, "-maxdepth", "3", "-type", "f",
             "-newermt", "-7 days", "-not", "-path", "*/.*"],
            capture_output=True, text=True, timeout=5)
        return [f for f in result.stdout.strip().split("\n") if f][:limit]
    except:
        return []

def get_system_context():
    ctx = [f"OS: NeurOS (Ubuntu 24.04)", f"CWD: {os.getcwd()}"]
    try:
        files = os.listdir(".")
        ctx.append(f"Directory contents: {', '.join(files[:20])}")
    except:
        pass
    try:
        branch = subprocess.check_output(
            ["git", "branch", "--show-current"],
            stderr=subprocess.DEVNULL, text=True).strip()
        if branch:
            ctx.append(f"Git branch: {branch}")
    except:
        pass
    try:
        diff = subprocess.check_output(
            ["git", "diff", "HEAD"],
            stderr=subprocess.DEVNULL, text=True, timeout=5).strip()
        if diff:
            if len(diff) > 3000:
                diff = diff[:3000] + "\n... (diff truncated)"
            ctx.append(f"Uncommitted changes (git diff HEAD):\n{diff}")
    except:
        pass

    # Opt-in system-wide context. Off by default; see [context] in llm.conf.
    settings = get_context_config()
    if settings["window_title"]:
        title = get_active_window_title()
        if title:
            ctx.append(f"Active window: {title}")
    if settings["clipboard"]:
        clip = get_clipboard_contents()
        if clip.strip():
            ctx.append(f"Clipboard contents:\n{clip}")
    if settings["recent_files"]:
        recents = get_recent_files()
        if recents:
            ctx.append(f"Recently modified files: {', '.join(recents)}")

    return "\n".join(ctx)

def read_readme_if_present():
    """Read README.md/README from the current directory, if one exists."""
    for name in ("README.md", "README"):
        if os.path.isfile(name):
            return read_file_safe(name)
    return ""

def read_file_safe(path):
    try:
        with open(path, 'r', errors='replace') as f:
            content = f.read()
            # Truncate very large files
            if len(content) > 8000:
                content = content[:8000] + "\n... (truncated)"
            return content
    except Exception as e:
        return f"(Could not read file: {e})"

def stream_response(prompt, model):
    try:
        resp = requests.post(OLLAMA_URL, json={
            "model": model,
            "prompt": prompt,
            "stream": True
        }, stream=True, timeout=120)
        resp.raise_for_status()
        for line in resp.iter_lines():
            if line:
                data = json.loads(line)
                print(data.get("response", ""), end="", flush=True)
                if data.get("done"):
                    print()
                    break
    except requests.exceptions.ConnectionError:
        print("Error: NeurOS LLM daemon is not running.")
        print("Start it with: sudo systemctl start neuros-llm")
    except Exception as e:
        print(f"Error: {e}")

def interactive_mode(model):
    print(f"NeurOS Assistant (model: {model}) — type 'exit' to quit\n")
    history = []
    while True:
        try:
            user_input = input(">> ").strip()
            if user_input.lower() in ("exit", "quit"):
                break
            if not user_input:
                continue
            history.append(user_input)
            ctx = get_system_context()
            history_str = "\n".join(f"User: {h}" for h in history[-5:])
            prompt = f"""You are a helpful Linux terminal assistant on NeurOS.
System context:
{ctx}

Conversation history:
{history_str}

Current question: {user_input}
Be concise. Wrap shell commands in backticks."""
            stream_response(prompt, model)
        except (KeyboardInterrupt, EOFError):
            print("\nExiting.")
            break

def main():
    args = sys.argv[1:]
    model = get_model()

    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    if args[0] == "-i":
        interactive_mode(model)
        return

    question = args[0]
    file_content = ""
    if len(args) > 1:
        file_content = read_file_safe(args[1])
    else:
        file_content = read_readme_if_present()

    ctx = get_system_context()
    prompt = f"""You are a helpful Linux terminal assistant on NeurOS.
System context:
{ctx}
{"File content:\\n" + file_content if file_content else ""}
User question: {question}
Be concise. If suggesting shell commands, wrap them in backticks."""

    stream_response(prompt, model)

if __name__ == "__main__":
    main()
