<script>
// State
let currentChatId = null;
let messages = [];
let currentModel = 'mistral';

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  loadModels();
  loadChatList();
  checkStatus();
  setInterval(checkStatus, 10000);
});

async function checkStatus() {
  try {
    const resp = await fetch('/api/status');
    const data = await resp.json();
    const dot = document.getElementById('statusDot');
    const label = document.getElementById('statusLabel');
    if (data.running) {
      dot.className = 'status-dot online';
      label.textContent = `Online (${data.models.length} models)`;
    } else {
      dot.className = 'status-dot offline';
      label.textContent = 'LLM Offline';
    }
  } catch(e) {
    document.getElementById('statusDot').className = 'status-dot offline';
    document.getElementById('statusLabel').textContent = 'Offline';
  }
}

async function loadModels() {
  try {
    const resp = await fetch('/api/models');
    const models = await resp.json();
    const select = document.getElementById('modelSelect');
    select.innerHTML = '';
    models.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m;
      opt.textContent = m;
      select.appendChild(opt);
    });
    if (models.length > 0) currentModel = models[0];
  } catch(e) {}
}

function onModelChange() {
  currentModel = document.getElementById('modelSelect').value;
}

async function loadChatList() {
  try {
    const resp = await fetch('/api/history');
    const chats = await resp.json();
    const list = document.getElementById('chatList');
    list.innerHTML = '';
    chats.forEach(chat => {
      const div = document.createElement('div');
      div.className = 'chat-list-item' + (chat.id === currentChatId ? ' active' : '');
      div.onclick = () => loadChat(chat.id);
      div.innerHTML = `
        <span>${escapeHtml(chat.title)}</span>
        <button class="delete-btn" onclick="event.stopPropagation(); deleteChat('${chat.id}')">×</button>
      `;
      list.appendChild(div);
    });
  } catch(e) {}
}

async function loadChat(id) {
  try {
    const resp = await fetch('/api/load/' + id);
    const chat = await resp.json();
    currentChatId = chat.id;
    messages = chat.messages || [];
    currentModel = chat.model || 'mistral';
    document.getElementById('modelSelect').value = currentModel;
    document.getElementById('chatTitle').textContent = chat.title;
    document.getElementById('welcomeScreen').style.display = 'none';
    renderMessages();
    loadChatList();
  } catch(e) {}
}

function newChat() {
  currentChatId = null;
  messages = [];
  document.getElementById('chatTitle').textContent = 'New Chat';
  document.getElementById('welcomeScreen').style.display = 'flex';
  document.getElementById('messagesContainer').innerHTML = `
    <div class="welcome-screen" id="welcomeScreen">
      <div class="logo">🧠</div>
      <h2>Welcome to NeurOS Chat</h2>
      <p>Your fully local AI assistant. Nothing leaves this machine.</p>
    </div>
  `;
  loadChatList();
}

function sendSuggestion(text) {
  document.getElementById('userInput').value = text;
  sendMessage();
}

async function sendMessage() {
  const input = document.getElementById('userInput');
  const prompt = input.value.trim();
  if (!prompt) return;

  document.getElementById('welcomeScreen').style.display = 'none';

  // Add user message
  messages.push({ role: 'user', content: prompt });
  renderMessages();

  input.value = '';
  document.getElementById('sendBtn').disabled = true;
  input.disabled = true;

  // Show typing indicator
  const container = document.getElementById('messagesContainer');
  const typing = document.createElement('div');
  typing.className = 'message';
  typing.id = 'typingIndicator';
  typing.innerHTML = `
    <div class="message-avatar ai">🤖</div>
    <div class="message-content">
      <div class="typing-indicator">
        <span></span><span></span><span></span>
      </div>
    </div>
  `;
  container.appendChild(typing);
  container.scrollTop = container.scrollHeight;

  try {
    const resp = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        prompt: prompt,
        model: currentModel,
        history: messages.slice(0, -1)
      })
    });

    const data = await resp.json();
    messages.push({ role: 'assistant', content: data.response });

    // Auto-title
    if (!currentChatId && messages.length === 2) {
      const title = prompt.slice(0, 50) + (prompt.length > 50 ? '...' : '');
      document.getElementById('chatTitle').textContent = title;
    }
  } catch(e) {
    messages.push({ role: 'assistant', content: 'Error: Could not reach the LLM. Is neuros-llm running?' });
  }

  // Remove typing indicator
  document.getElementById('typingIndicator')?.remove();
  renderMessages();

  document.getElementById('sendBtn').disabled = false;
  input.disabled = false;
  input.focus();
}

function renderMessages() {
  const container = document.getElementById('messagesContainer');
  container.innerHTML = '';

  messages.forEach((msg, i) => {
    const isUser = msg.role === 'user';
    const div = document.createElement('div');
    div.className = 'message';
    div.innerHTML = `
      <div class="message-avatar ${isUser ? 'user' : 'ai'}">${isUser ? '👤' : '🤖'}</div>
      <div class="message-content">
        <div class="message-role">${isUser ? 'You' : 'NeurOS'}</div>
        <div class="message-text">${formatMessage(msg.content)}</div>
      </div>
    `;
    container.appendChild(div);
  });

  container.scrollTop = container.scrollHeight;
}

function formatMessage(text) {
  // Escape HTML
  let escaped = escapeHtml(text);

  // Code blocks with triple backticks
  escaped = escaped.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>');

  // Inline code
  escaped = escaped.replace(/`([^`]+)`/g, '<code>$1</code>');

  // Bold and italic
  escaped = escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  escaped = escaped.replace(/\*(.+?)\*/g, '<em>$1</em>');

  // Line breaks to paragraphs
  escaped = escaped.replace(/\n\n/g, '</p><p>');
  escaped = '<p>' + escaped + '</p>';

  // Clean empty paragraphs
  escaped = escaped.replace(/<p><\/p>/g, '');

  return escaped;
}

function escapeHtml(text) {
  const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
  return text.replace(/[&<>"']/g, c => map[c]);
}

async function saveChat() {
  if (messages.length === 0) return;
  const title = document.getElementById('chatTitle').textContent;

  const resp = await fetch('/api/save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      id: currentChatId,
      title: title,
      model: currentModel,
      messages: messages
    })
  });

  const data = await resp.json();
  currentChatId = data.id;
  await loadChatList();
}

async function deleteChat(id) {
  if (!confirm('Delete this chat?')) return;
  await fetch('/api/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id })
  });
  if (currentChatId === id) newChat();
  loadChatList();
}

function handleKeyDown(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

// Auto-resize textarea
document.addEventListener('DOMContentLoaded', () => {
  const textarea = document.getElementById('userInput');
  textarea.addEventListener('input', () => {
    textarea.style.height = 'auto';
    textarea.style.height = Math.min(textarea.scrollHeight, 200) + 'px';
  });
});
</script>

</body>
</html>"""

def main():
    parser = argparse.ArgumentParser(description="NeurOS Chat Server")
    parser.add_argument("--port", type=int, default=DEFAULT_PORT, help=f"Port (default: {DEFAULT_PORT})")
    parser.add_argument("--no-browser", action="store_true", help="Don't open browser")
    args = parser.parse_args()

    server = HTTPServer(("127.0.0.1", args.port), ChatHandler)
    url = f"http://localhost:{args.port}"

    print(f"""
╔══════════════════════════════════════════╗
║          🧠 NeurOS Chat                  ║
║          Local AI Chat Interface          ║
╠══════════════════════════════════════════╣
║  Server:  {url:<29}║
║  Model:   Mistral 7B (local)             ║
║  Privacy: Nothing leaves this machine    ║
╚══════════════════════════════════════════╝

Press Ctrl+C to stop.
""")

    if not args.no_browser:
        def open_browser():
            time.sleep(1)
            try:
                subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except Exception:
                pass
        threading.Thread(target=open_browser, daemon=True).start()

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down...")
        server.shutdown()

if __name__ == "__main__":
    main()
