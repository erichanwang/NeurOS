#!/usr/bin/env python3
"""
neuros-chat — NeurOS Web Chat Server
Launches a local Flask web server with a beautiful chat UI.
Access at http://localhost:11435

Usage:
  neuros-chat              # Start server (default port 11435)
  neuros-chat --port 8080  # Custom port
  neuros-chat --no-browser # Don't auto-open browser
"""

import sys
import os
import json
import subprocess
import threading
import time
import argparse
import hashlib
from datetime import datetime
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs
import html

OLLAMA_URL = "http://localhost:11434/api"
DEFAULT_PORT = 11435
CHAT_HISTORY_DIR = os.path.expanduser("~/.config/neuros/chats")

# Ensure chat history directory
os.makedirs(CHAT_HISTORY_DIR, exist_ok=True)

def get_models():
    """Get list of available models from Ollama."""
    try:
        import urllib.request
        req = urllib.request.Request(f"{OLLAMA_URL}/tags")
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
            return [m["name"] for m in data.get("models", [])]
    except Exception:
        return ["mistral"]

def chat_with_ollama(model, prompt, history=None):
    """Send a chat request to Ollama and parse response."""
    import urllib.request

    messages = []
    if history:
        for h in history[-10:]:
            messages.append({"role": h["role"], "content": h["content"]})
    messages.append({"role": "user", "content": prompt})

    data = json.dumps({
        "model": model,
        "messages": messages,
        "stream": False
    }).encode('utf-8')

    try:
        req = urllib.request.Request(
            f"{OLLAMA_URL}/chat",
            data=data,
            headers={"Content-Type": "application/json"}
        )
        with urllib.request.urlopen(req, timeout=300) as resp:
            result = json.loads(resp.read())
            return result.get("message", {}).get("content", "No response.")
    except Exception as e:
        return f"Error: {e}"

class ChatHandler(BaseHTTPRequestHandler):
    """HTTP request handler for the chat server."""

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path

        if path == "/" or path == "/index.html":
            self.serve_html()
        elif path == "/api/models":
            self.serve_json(get_models())
        elif path == "/api/history":
            self.serve_chat_history()
        elif path.startswith("/api/load/"):
            chat_id = path.split("/")[-1]
            self.serve_chat_load(chat_id)
        elif path == "/api/status":
            self.serve_ollama_status()
        else:
            self.send_error(404)

    def do_POST(self):
        parsed = urlparse(self.path)
        path = parsed.path
        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length)

        try:
            data = json.loads(body)
        except json.JSONDecodeError:
            self.send_error(400, "Invalid JSON")
            return

        if path == "/api/chat":
            self.handle_chat(data)
        elif path == "/api/save":
            self.handle_save_chat(data)
        elif path == "/api/delete":
            self.handle_delete_chat(data)
        else:
            self.send_error(404)

    def serve_html(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.end_headers()
        self.wfile.write(CHAT_HTML.encode('utf-8'))

    def serve_json(self, data):
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.end_headers()
        self.wfile.write(json.dumps(data).encode('utf-8'))

    def serve_ollama_status(self):
        try:
            import urllib.request
            req = urllib.request.Request(f"{OLLAMA_URL.split('/api')[0]}:11434/api/tags")
            with urllib.request.urlopen(req, timeout=3) as resp:
                data = json.loads(resp.read())
                self.serve_json({"running": True, "models": [m["name"] for m in data.get("models", [])]})
        except Exception:
            self.serve_json({"running": False, "models": []})

    def serve_chat_history(self):
        chats = []
        try:
            for fname in sorted(os.listdir(CHAT_HISTORY_DIR), reverse=True):
                if fname.endswith('.json'):
                    fpath = os.path.join(CHAT_HISTORY_DIR, fname)
                    with open(fpath) as f:
                        chat = json.load(f)
                        chats.append({
                            "id": fname.replace('.json', ''),
                            "title": chat.get("title", "Untitled"),
                            "model": chat.get("model", ""),
                            "timestamp": chat.get("timestamp", ""),
                            "message_count": len(chat.get("messages", []))
                        })
        except Exception:
            pass
        self.serve_json(chats)

    def serve_chat_load(self, chat_id):
        try:
            fpath = os.path.join(CHAT_HISTORY_DIR, f"{chat_id}.json")
            with open(fpath) as f:
                self.serve_json(json.load(f))
        except Exception:
            self.send_error(404, "Chat not found")

    def handle_chat(self, data):
        prompt = data.get("prompt", "")
        model = data.get("model", "mistral")
        history = data.get("history", [])

        response = chat_with_ollama(model, prompt, history)
        self.serve_json({"response": response, "model": model})

    def handle_save_chat(self, data):
        chat_id = data.get("id") or hashlib.md5(str(time.time()).encode()).hexdigest()[:12]
        fpath = os.path.join(CHAT_HISTORY_DIR, f"{chat_id}.json")

        chat_data = {
            "id": chat_id,
            "title": data.get("title", "Untitled Chat"),
            "model": data.get("model", "mistral"),
            "timestamp": datetime.now().isoformat(),
            "messages": data.get("messages", [])
        }

        with open(fpath, 'w') as f:
            json.dump(chat_data, f, indent=2)

        self.serve_json({"id": chat_id, "saved": True})

    def handle_delete_chat(self, data):
        chat_id = data.get("id")
        try:
            fpath = os.path.join(CHAT_HISTORY_DIR, f"{chat_id}.json")
            os.remove(fpath)
            self.serve_json({"deleted": True})
        except Exception:
            self.send_error(404, "Chat not found")

    def log_message(self, format, *args):
        """Suppress default logging."""
        pass


